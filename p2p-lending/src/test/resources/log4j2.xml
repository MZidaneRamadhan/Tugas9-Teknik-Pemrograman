<?xml version="1.0" encoding="UTF-8"?>
<Configuration>
    <Appenders>
        <!-- Console Appender untuk test output -->
        <Console name="ConsoleAppender" target="SYSTEM_OUT">
            <PatternLayout 
                pattern="%d{HH:mm:ss.SSS} [%-5level] %c{1} - %msg%n" />
        </Console>

        <!-- File Appender untuk test logs -->
        <File name="TestFileAppender" fileName="logs/test.log">
            <PatternLayout 
                pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%-5level] [%t] %c{1} - %msg%n" />
        </File>
    </Appenders>

    <Loggers>
        <!-- Logger untuk test -->
        <Logger name="com.p2p" level="DEBUG" additivity="false">
            <AppenderRef ref="ConsoleAppender" />
            <AppenderRef ref="TestFileAppender" />
        </Logger>

        <!-- Root Logger untuk test -->
        <Root level="INFO">
            <AppenderRef ref="ConsoleAppender" />
        </Root>
    </Loggers>
</Configuration>
